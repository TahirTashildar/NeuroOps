# Environment variables for Vercel deployment
# Copy this file to .env.local and fill in the values

# API Configuration
API_BASE=https://your-vercel-project.vercel.app/api
API_HOST=your-vercel-project.vercel.app
API_PORT=443

# Node Environment
NODE_ENV=production

# Frontend Configuration
NEXT_PUBLIC_API_BASE=https://your-vercel-project.vercel.app/api

# Optional: Add custom domain
# VERCEL_URL=neuro-ops.example.com
